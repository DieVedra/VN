  namenode: 
  _localizationText:
    <DefaultText>k__BackingField: "\u042F \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0430,
      \u043A\u0430\u043A \u043B\u0443\u043D\u043D\u044B\u0439 \u0441\u0432\u0435\u0442
      \u043D\u0435\u0436\u043D\u043E \u0433\u043B\u0430\u0434\u0438\u0442 \u043C\u043E\u0435
      \u0442\u0435\u043B\u043E, \u043A\u0430\u043A \u0437\u0430\u043F\u0430\u0445
      \u0441\u043E\u043B\u0438 \u043D\u0430\u043F\u043E\u043B\u043D\u044F\u0435\u0442
      \u0441\u0432\u0435\u0436\u0435\u0441\u0442\u044C\u044E \u0432\u0441\u0435 \u0432\u043E\u043A\u0440\u0443\u0433,
      \u043A\u0430\u043A \u0437\u0432\u0443\u043A\u0438 \u043C\u043E\u0440\u044F,
      \u0431\u0443\u0434\u0442\u043E \u043F\u0435\u0441\u043D\u044F, \u0437\u0430\u0437\u044B\u0432\u0430\u044E\u0442
      \u043C\u0435\u043D\u044F \u0432 \u0441\u0432\u043E\u0435 \u043D\u0435\u043E\u0431\u044A\u044F\u0442\u043D\u043E\u0435
      \u043B\u043E\u043D\u043E."
