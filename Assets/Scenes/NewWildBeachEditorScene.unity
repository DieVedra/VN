  _backgroundContentDictionary:
    m_Keys:
    - "\u0413\u043E\u0440\u044B \u0438 \u043F\u043B\u044F\u0436 (\u0437\u0430\u043A\u0430\u0442)"
    - "\u041F\u043B\u044F\u0436 (\u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442
      - \u043C\u043E\u0440\u0435_ \u0441\u043E\u043B\u043D\u0446\u0435 \u0432 \u0437\u0435\u043D\u0438\u0442\u0435)"
    - "\u041F\u043B\u044F\u0436 \u0438 \u0433\u043E\u0440\u044B(\u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442
      - \u0433\u043E\u0440\u044B, \u0441\u043A\u0430\u043B\u044B_ \u0441\u043E\u043B\u043D\u0446\u0435
      \u0432 \u0437\u0435\u043D\u0438\u0442\u0435)"
    - "\u041A\u0443\u0441\u0442\u044B(\u043D\u043E\u0447\u044C)"
    - "\u041B\u0435\u0441 (\u043D\u043E\u0447\u044C)"
    - "\u041B\u0435\u0441 \u0437\u0430\u043A\u0430\u0442"
    - "\u041B\u0435\u0441 \u043F\u0435\u043D\u0442\u0430\u0433\u0440\u0430\u043C\u043C\u0430
      (\u0434\u0435\u043D\u044C)"
    - "\u041F\u043B\u044F\u0436 \u0441 \u043F\u0430\u043B\u0430\u0442\u043A\u043E\u0439
      (\u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442 - \u0433\u043E\u0440\u044B,
      \u0441\u043A\u0430\u043B\u044B_ \u043D\u043E\u0447\u044C)."
    - "\u0423\u0442\u0435\u0441 \u0441 \u0432\u0438\u0434\u043E\u043C \u043D\u0430
      \u0433\u043E\u0440\u044B \u0438 \u043C\u043E\u0440\u0435"
    - "\u0434\u0432\u0435\u0440\u044C-\u0432\u0445\u043E\u0434 \u0432 \u043A\u043B\u0443\u0431"
    - "\u043A\u043B\u0443\u0431 (\u044D\u0444\u0444\u0435\u043A\u0442 \u043F\u044C\u044F\u043D\u044B\u0445
      \u0433\u043B\u0430\u0437)"
    - "\u043A\u043B\u0443\u0431-\u0442\u0430\u043D\u0446\u043F\u043E\u043B"
    - "\u043A\u043B\u0443\u0431-\u0445\u043E\u043B\u043B"
    - "\u043A\u0443\u0441\u0442\u044B (\u0434\u0435\u043D\u044C)"
    - BlackBackground
    - "\u043A\u0430\u043C\u0435\u043D\u0438\u0441\u0442\u044B\u0439 \u043F\u043B\u044F\u0436
      (\u0433\u043E\u0440\u0438\u0437\u043E\u043D\u0442_\u0441\u043A\u0430\u043B\u044B,
      \u0432\u0440\u0435\u043C\u044F_\u0443\u0442\u0440\u043E)"
    - "\u043A\u0430\u043C\u0435\u043D\u0438\u0441\u0442\u044B\u0439 \u043F\u043B\u044F\u0436
      (\u044D\u0444\u0444\u0435\u043A\u0442 \u043F\u044C\u044F\u043D\u044B\u0445
      \u0433\u043B\u0430\u0437)"
    - "\u043F\u043B\u044F\u0436 (\u044D\u0444\u0444\u0435\u043A\u0442 \u0432\u043E\u0434\u043E\u0432\u043E\u0440\u043E\u0442)."
    - "\u0423\u0447\u0430\u0441\u0442\u043E\u043A"
    - "\u0411\u0435\u043B\u044B\u0439 \u0444\u043E\u043D"
    - "\u043A\u0432\u0430\u0440\u0442\u0438\u0440\u0430 \u041C\u0430\u0440\u043A\u0430,
