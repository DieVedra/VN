  namenode: 
  _localizationText:
    <DefaultText>k__BackingField: "\u0412 \u043C\u043E\u0435\u0439 \u0433\u043E\u043B\u043E\u0432\u0435
      \u0441\u0440\u0430\u0436\u0430\u043B\u0438\u0441\u044C \u0434\u0435\u043C\u043E\u043D\u044B,
      \u043F\u0435\u0440\u0435\u0442\u044F\u0433\u0438\u0432\u0430\u044E\u0449\u0438\u0435
      \u043C\u043E\u0438 \u0441\u0443\u0436\u0434\u0435\u043D\u0438\u044F \u0438\u0437
      \u0441\u0442\u043E\u0440\u043E\u043D\u044B \u0432 \u0441\u0442\u043E\u0440\u043E\u043D\u0443.
      \u0421 \u043E\u0434\u043D\u043E\u0439 \u0441\u0442\u043E\u0440\u043E\u043D\u044B,
      \u044F \u0447\u0443\u0432\u0441\u0442\u0432\u043E\u0432\u0430\u043B\u0430 \u043D\u0435\u0434\u043E\u0432\u0435\u0440\u0438\u0435
      \u043A \u041C\u0430\u0440\u043A\u0443 \u043F\u043E\u0441\u043B\u0435 \u043A\u043B\u0443\u0431\u0430
      \u0438 \u0445\u043E\u0442\u0435\u043B\u0430 \u043D\u0430\u043A\u043E\u043D\u0435\u0446
      \u043F\u043E\u043D\u044F\u0442\u044C \u043A\u0442\u043E \u043E\u043D \u0442\u0430\u043A\u043E\u0439."
    <Key>k__BackingField: str_740232FE
